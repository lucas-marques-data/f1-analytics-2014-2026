print("\n4.1 HEATMAP — VITORIAS POR EQUIPE E ANO")
wins_hm = winners.groupby(['constructor_name','year']).size().reset_index(name='wins')
hm_data = wins_hm.pivot(index='constructor_name', columns='year', values='wins').fillna(0)
